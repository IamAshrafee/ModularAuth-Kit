# ============================================================
# ModularAuth-Kit — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ============================================================

# ─── SERVER ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── DATABASE ───────────────────────────────────────────────
# MongoDB connection string
# Example: mongodb://localhost:27017/your_database_name
MONGODB_URI=mongodb://localhost:27017/modularauth

# ─── SESSION ────────────────────────────────────────────────
# A long, random secret string for signing session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_STRING

# ─── GOOGLE OAUTH (optional — only if Google login is enabled) ───
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── EMAIL / SMTP (optional — only if email features are enabled) ───
# Required for: forgot-password, email verification
# Example SMTP providers: Gmail, SendGrid, Mailgun, AWS SES
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourapp.com
